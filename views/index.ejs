<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ghoripara</title>
    <link rel="stylesheet" href="/css/output.css" />
  </head>
  <body class="bg-black flex w-full justify-start items-center h-full flex-col">
    <nav
      class="flex justify-center gap-50 items-center px-10 w-full bg-white h-30"
    >
      <h1 class="text-5xl font-extrabold">Ghoripara</h1>
      <ul class="flex items-center justify-center gap-10 text-xl">
        <a href="#home"
          ><li class="hover:underline underline-offset-4 decoration-2">
            Home
          </li></a
        >
        <a href="#about-us"
          ><li class="hover:underline underline-offset-4 decoration-2">
            About Us
          </li></a
        >
        <a href="#woat"
          ><li class="hover:underline underline-offset-4 decoration-2">
            W.O.A.T
          </li></a
        >
        <a href="#bts">
          <li class="hover:underline underline-offset-4 decoration-2">
            Behind The Gears
          </li>
        </a>
        <a href="#newsletter">
          <li class="hover:underline underline-offset-4 decoration-2">
            Newsletter
          </li></a
        >
      </ul>
      <ul class="flex items-center justify-center gap-8 text-lg text-gray-600">
        <li class="px-6 py-3 bg-black text-white shadow-xl">
          <a href="/register">Sign Up</a>
        </li>
        <li class="px-6 py-3 bg-black text-white shadow-xl">
          <a href="/login">Log In</a>
        </li>
      </ul>
    </nav>
    <section id="home" class="w-full h-screen bg-white text-black flex">
      <img
        src="/images/banner1.webp"
        alt="banner-1"
        class="object-cover w-1/3 h-full shadow-xl"
      />
      <div
        class="w-1/3 h-full p-5 flex flex-col justify-center items-center gap-6"
      >
        <div class="flex flex-col gap-2">
          <p class="text-3xl font-light tracking-widest">Welcome to,</p>
          <p class="text-6xl font-extrabold">Ghoripara</p>
          <p
            class="self-center text-xl italic font-extralight tracking-widest text-gray-500"
          >
            "Time is Money"
          </p>
        </div>
        <p class="text-xl font-extralight tracking-widest">
          Wear your time and be a time keeper yourself
        </p>
        <div class="flex w-full justify-center items-center gap-6">
          <a class="px-6 py-3 bg-black text-white shadow-xl" href="">Explore</a>
          <a class="px-6 py-3 bg-black text-white shadow-xl" href="/register"
            >Join Us</a
          >
        </div>
      </div>
      <img
        src="/images/banner2.webp"
        alt="banner-2"
        class="object-cover w-1/3 h-full shadow-xl"
      />
    </section>
    <section class="w-full flex h-screen bg-gray-200" id="about-us">
      <div
        class="w-1/2 h-full flex flex-col justify-center items-center gap-10 p-10"
      >
        <h1 class="text-6xl font-bold">About Us</h1>
        <div class="grid grid-cols-2 grid-rows-2 gap-6">
          <div
            class="flex flex-col justify-start items-center p-7 text-center gap-4"
          >
            <h2 class="text-2xl font-semibold">Precision Engineering:</h2>
            <p class="text-lg/8 tracking-widest">
              Masterfully crafted mechanisms ensure accuracy to the second,
              embodying reliability in every tick. Japanese quartz movements and
              sapphire crystals deliver unmatched durability.
            </p>
          </div>
          <div
            class="flex flex-col justify-start items-center p-7 text-center gap-4"
          >
            <h2 class="text-2xl font-semibold">Timeless Investment:</h2>
            <p class="text-lg/8 tracking-widest">
              Unlike fleeting trends, our watches appreciate with
              age—collector's pieces that gain value through heritage and
              scarcity. Wearable heirlooms for generations.
            </p>
          </div>
          <div
            class="flex flex-col justify-start items-center p-7 text-center gap-4"
          >
            <h2 class="text-2xl font-semibold">Discipline Manifested:</h2>
            <p class="text-lg/8 tracking-widest">
              Each glance at your wrist reinforces intentional living. Time
              isn't wasted; it's seized, measured, and maximized through
              deliberate design.
            </p>
          </div>
          <div
            class="flex flex-col justify-start items-center p-7 text-center gap-4"
          >
            <h2 class="text-2xl font-semibold">Legacy in Motion:</h2>
            <p class="text-lg/8 tracking-widest">
              Beyond functionality, Ghoripara watches symbolize earned
              authority. Presidents wear Rolex. Moguls wear Patek. Leaders wear
              Ghoripara.
            </p>
          </div>
        </div>
      </div>
      <img
        src="/images/aboutus.webp"
        alt="banner-1"
        class="object-cover w-1/2 h-full shadow-xl"
      />
    </section>
    <section
      class="relative w-full h-screen bg-white overflow-hidden flex justify-center items-center"
      id="woat"
    >
      <img
        id="watch-img"
        class="absolute inset-0 w-full h-full object-center z-0"
        alt=""
      />
      <div class="absolute inset-0 bg-black/80 z-10"></div>

      <div
        class="relative z-20 flex h-full w-2/3 items-center justify-center p-10 text-white flex-col text-center gap-6"
      >
        <h2 class="text-5xl font-bold">W.O.A.T</h2>
        <p class="text-xl/10 tracking-widest italic mt-4">
          More than an accessory, this is a statement forged in steel, detail,
          and discipline. Every curve, every finish, and every movement is
          designed to reflect timeless character rather than temporary trend.
        </p>
        <p class="text-xl/10 tracking-widest italic">
          Built for those who respect precision, this piece brings together
          refined craftsmanship, bold presence, and lasting value. It is not
          made to follow time—it is made to define it.
        </p>
        <a
          class="px-8 py-4 bg-white text-xl text-black shadow-xl"
          href="/explore"
          >Explore</a
        >
      </div>
    </section>
    <section class="w-full flex h-screen bg-gray-100 p-10 gap-6" id="bts">
      <div class="grid grid-cols-2 grid-rows-12 gap-5 w-1/2 h-full">
        <img
          src="/images/btgpot.webp"
          class="object-cover size-full col-span-2 row-span-8 rounded-4xl shadow-2xl"
        />
        <img
          src="/images/btgsq1.webp"
          class="object-cover size-full row-span-4 row-start-9 rounded-4xl shadow-2xl"
        />
        <img
          src="/images/btgsq2.webp"
          class="object-cover size-full row-span-4 row-start-9 rounded-4xl shadow-2xl"
        />
      </div>
      <div
        class="w-1/2 flex flex-col justify-center items-center gap-6 text-center p-5"
      >
        <h2 class="text-6xl font-bold">Behind the Gears</h2>
        <p class="text-xl/10 tracking-widest mt-4">
          Beneath every polished case lies a world of discipline, precision, and
          purpose. From the movement that drives each second to the finishing
          that refines every visible detail, our watches are built to honor both
          engineering and elegance.
        </p>
        <p class="text-xl/10 tracking-widest">
          Beneath every polished case lies a world of discipline, precision, and
          purpose. From the movement that drives each second to the finishing
          that refines every visible detail, our watches are built to honor both
          engineering and elegance.
        </p>
      </div>
    </section>
    <section
      class="w-full flex text-center flex-col h-screen bg-gray-600 text-white justify-center items-center p-10 gap-10"
      id="newsletter"
    >
      <h2 class="text-6xl font-bold">Stay in Time with Ghoripara</h2>
      <p class="tracking-widest text-xl/10 w-2/3">
        Be the first to discover new arrivals, limited releases, and stories
        from behind the craft. Join our circle for curated updates made for
        those who value precision, legacy, and timeless design.
      </p>
      <form class="w-full max-w-2xl flex gap-4">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-6 py-4 rounded-full bg-white text-black outline-none"
        />
        <button
          class="px-8 py-4 rounded-full bg-white text-black font-semibold cursor-pointer hover:bg-gray-200"
        >
          Subscribe
        </button>
      </form>
    </section>
    <footer class="w-full bg-black text-white px-10 py-14 flex flex-col gap-10">
      <div
        class="w-full grid grid-cols-3 gap-10 border-b border-white/15 pb-10"
      >
        <div class="flex flex-col gap-4">
          <h2 class="text-4xl font-bold">Ghoripara</h2>
          <p class="text-gray-400 leading-7 max-w-md">
            Ghoripara is built for those who value precision, presence, and
            timeless craftsmanship. More than watches, we curate statements that
            outlive trends.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <h3 class="text-2xl font-semibold">Quick Links</h3>
          <ul class="flex flex-col gap-3 text-gray-300">
            <li class="hover:text-white transition">
              <a href="#home">Home</a>
            </li>
            <li class="hover:text-white transition">
              <a href="#about-us">About Us</a>
            </li>
            <li class="hover:text-white transition">
              <a href="#woat">W.O.A.T.</a>
            </li>
            <li class="hover:text-white transition">
              <a href="#bts">Behind The Gears</a>
            </li>
            <li class="hover:text-white transition">
              <a href="#newsletter">Newsletter</a>
            </li>
          </ul>
        </div>

        <div class="flex flex-col gap-4">
          <h3 class="text-2xl font-semibold">Contact</h3>
          <ul class="flex flex-col gap-3 text-gray-300">
            <li>
              Email:
              <a
                href="mailto:hello@ghoripara.com"
                class="hover:text-white transition"
              >
                hello@ghoripara.com
              </a>
            </li>
            <li>
              Phone:
              <a href="tel:+910000000000" class="hover:text-white transition">
                +91 00000 00000
              </a>
            </li>
            <li>Kolkata, West Bengal, India</li>
          </ul>

          <div class="flex gap-4 mt-2">
            <a href="#" class="hover:text-gray-300 transition">Instagram</a>
            <a href="#" class="hover:text-gray-300 transition">Facebook</a>
            <a href="#" class="hover:text-gray-300 transition">X</a>
          </div>
        </div>
      </div>

      <div
        class="w-full flex justify-between items-center text-sm text-gray-500"
      >
        <p>
          &copy; <%= new Date().getFullYear() %> Ghoripara. All rights reserved.
        </p>
        <div class="flex gap-6">
          <a href="#" class="hover:text-white transition">Privacy Policy</a>
          <a href="#" class="hover:text-white transition">Terms of Service</a>
        </div>
      </div>
    </footer>
    <script src="/js/script.js"></script>
  </body>
</html>
